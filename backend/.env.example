# Set automatically by bin entrypoints: api | worker | scheduler
# LOG_PROCESS=api

PORT=3000
BASE_URL=http://localhost:3000
JWT_SECRET=change-me-to-a-long-random-string

# MongoDB — URL without db path; database name separate (Atlas-friendly)
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DATABASE=vnvtuber

# Redis — ioredis connection URL (local or Upstash TLS)
REDIS_URL=redis://127.0.0.1:6379
