# Server Configuration
PORT=3000
BASE_URL=https://your-domain.com

# YouTube API Configuration
# Support rotating multiple API keys by separating them with commas (e.g. key1,key2,key3)
YOUTUBE_API_KEYS=YOUR_YOUTUBE_API_KEY_1,YOUR_YOUTUBE_API_KEY_2

# Redis Connection (For BullMQ queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Database Configuration
# MongoDB connection URI (e.g. mongodb://127.0.0.1:27017/vnvtuber)
MONGO_URI=mongodb://127.0.0.1:27017/vnvtuber

# Livestream Polling Intervals (milliseconds)
# 2 minutes for live streams, 10 minutes for upcoming streams
POLL_INTERVAL_LIVE_MS=120000
POLL_INTERVAL_UPCOMING_MS=600000

# WebSub Configuration
# Delay between subscription requests to prevent YouTube Hub rate limiting
WEBSUB_STAGGER_DELAY_MS=1000

# Notification Broker Integration
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_DISCORD_WEBHOOK_HERE
