# Copy to .env on the server: cp .env.example .env
# No application source code required — only this file + docker-compose.yml

DOCKER_IMAGE=ghcr.io/<github-owner>/<repo>/vnvtuber-backend:latest
API_PORT=3000

BASE_URL=https://api.your-domain.com
JWT_SECRET=replace-with-long-random-string
YOUTUBE_API_KEYS=key1,key2

# Atlas (compose stack without local Mongo):
# MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net
# MONGO_DATABASE=vnvtuber
#
# Default all-in-one compose overrides:
# MONGO_URL=mongodb://mongodb:27017
# MONGO_DATABASE=vnvtuber
# REDIS_HOST=redis

CORS_ORIGINS=https://your-frontend.com,https://admin.your-domain.com
TRUST_PROXY=true

# VPS 4 GB — see deploy/README.md
WEBHOOK_WORKER_CONCURRENCY=2
SUBSCRIPTION_WORKER_CONCURRENCY=2
WEBSUB_STAGGER_DELAY_MS=1000
POLL_INTERVAL_LIVE_MS=120000
POLL_INTERVAL_UPCOMING_MS=600000

ENABLE_DISCORD_NOTIFY=false
DISCORD_WEBHOOK_URL=
ENABLE_STREAM_SNAPSHOTS=false
