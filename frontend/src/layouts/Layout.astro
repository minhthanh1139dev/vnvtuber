---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { 
	title = "VNVtuber Hub - Mạng Lưới VTuber Việt Nam", 
	description = "Tổng hợp và giám sát trạng thái livestream của cộng đồng VTuber Việt Nam thời gian thực. Cập nhật thông tin kênh, livestream đang hoạt động và danh sách dự án nổi bật." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="vi">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/og-image.jpg" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />

		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<!-- Instantly apply premium theme if active -->
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('vnvtuber-theme') || 'default';
				if (theme !== 'default') {
					document.documentElement.classList.add('theme-' + theme);
				}
			})();
		</script>
	</head>
	<body class="bg-brand-bg text-zinc-100 min-h-screen flex flex-col justify-between antialiased selection:bg-neon-purple/30 selection:text-white">
		<div>
			{/* Gorgeous Dark Glowing Header Nav */}
			<header class="sticky top-4 mx-auto w-[92%] max-w-6xl z-50 border border-brand-border bg-[#110d21]/75 backdrop-blur-xl rounded-2xl shadow-xl shadow-black/35">
				<div class="flex flex-col sm:flex-row justify-between items-center py-4 px-6 sm:px-8 gap-4">
					<a href="/" class="flex items-center gap-2 group cursor-pointer">
						<span class="text-xl animate-bounce">✨</span>
						<span class="font-display text-xl font-extrabold tracking-tight">
							VN<span class="bg-gradient-to-r from-neon-purple to-neon-pink bg-clip-text text-transparent group-hover:brightness-110 transition-all duration-300">Vtuber</span> Hub
						</span>
					</a>
					<nav class="flex gap-2 text-xs font-semibold text-zinc-400">
						<a href="/#live" class="px-4 py-2 rounded-xl hover:bg-[#1f1636]/60 hover:text-zinc-100 transition-all duration-200">🔴 Live Now</a>
						<a href="/#directory" class="px-4 py-2 rounded-xl hover:bg-[#1f1636]/60 hover:text-zinc-100 transition-all duration-200">📋 VTuber List</a>
						<a href="/#suggest" class="px-4 py-2 rounded-xl hover:bg-[#1f1636]/60 hover:text-zinc-100 transition-all duration-200">💜 Gợi Ý Kênh</a>
					</nav>
				</div>
			</header>

			{/* Main Container Wrapper */}
			<main class="max-w-6xl mx-auto px-6 min-h-[75vh] mt-8">
				<slot />
			</main>
		</div>

		{/* Futuristic Glass Footer */}
		<footer class="mt-20 mb-6 mx-auto w-[92%] max-w-6xl p-6 border border-brand-border bg-[#110d21]/55 backdrop-blur-lg rounded-2xl text-center space-y-2 shadow-2xl">
			<p class="text-xs font-semibold text-zinc-400">
				© 2026 VN<span class="bg-gradient-to-r from-neon-purple to-neon-pink bg-clip-text text-transparent font-bold">Vtuber</span> Hub. Phát triển bởi cộng đồng yêu thích VTuber Việt Nam.
			</p>
			<p class="text-[10px] text-zinc-500 max-w-md mx-auto leading-relaxed">
				Hệ thống hoàn toàn phi thương mại. Mọi hình ảnh, avatar, nội dung livestream thuộc bản quyền sở hữu của các VTuber tương ứng.
			</p>
		</footer>
	</body>
</html>
